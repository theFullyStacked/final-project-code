#include "ArduinoIoTCloud.h"
#include "thingProperties.h"
#include <WiFi.h>
#include <HTTPClient.h>

// ===== FLOW SENSOR =====
#define FLOW_SENSOR_PIN 14   // GPIO for flow sensor

volatile int pulseCount = 0;
float flowRate = 0.0;
float totalVolume = 0.0;

unsigned long lastTime = 0;

// Calibration factor (depends on sensor, YF-S201 ≈ 7.5)
const float calibrationFactor = 7.5;

// ===== WiFi & Cloud =====
const char* WIFI_SSID = "Unbound";
const char* WIFI_PASS = "12345678";

const char* SHEET_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbyoXAnA76Zj0xEEuLW6H2YkSs4WKvfkkt4JIQAxwHwoiZmU5ah4FQrqiT69FepqGLA3Ug/exec";

unsigned long lastSendMillis = 0;
const unsigned long sendInterval = 5000;

// ===== Leak Detection =====
bool leakDetected = false;

// ===== Interrupt Function =====
void IRAM_ATTR pulseCounter() {
  pulseCount++;
}

// ===== Setup =====
void setup() {
  Serial.begin(115200);

  initProperties();
  ArduinoCloud.begin(ArduinoIoTPreferredConnection);

  pinMode(FLOW_SENSOR_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR_PIN), pulseCounter, FALLING);

  WiFi.begin(WIFI_SSID, WIFI_PASS);

  lastTime = millis();
}

// ===== Loop =====
void loop() {
  ArduinoCloud.update();

  calculateFlow();
  detectLeak();
  sendToGoogleSheets();

  delay(1000);
}

// ===== Flow Calculation =====
void calculateFlow() {
  unsigned long currentTime = millis();

  if (currentTime - lastTime >= 1000) {
    detachInterrupt(FLOW_SENSOR_PIN);

    // Flow rate (L/min)
    flowRate = ((1000.0 / (currentTime - lastTime)) * pulseCount) / calibrationFactor;

    // Volume (Litres)
    float flowLitres = flowRate / 60.0;
    totalVolume += flowLitres;

    // Update cloud variables
    flow_rate = flowRate;
    total_volume = totalVolume;

    Serial.print("Flow Rate: ");
    Serial.print(flowRate);
    Serial.print(" L/min | Total Volume: ");
    Serial.println(totalVolume);

    pulseCount = 0;
    lastTime = millis();

    attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR_PIN), pulseCounter, FALLING);
  }
}

// ===== Leak Detection =====
void detectLeak() {
  // Simple logic: continuous low flow → possible leak
  if (flowRate > 0.2 && flowRate < 1.0) {
    leakDetected = true;
    message = "Possible Leak Detected";
  } else {
    leakDetected = false;
  }

  leak_status = leakDetected;
}

// ===== Google Sheets Upload =====
void sendToGoogleSheets() {
  if (millis() - lastSendMillis < sendInterval) return;
  lastSendMillis = millis();

  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;
  http.begin(SHEET_SCRIPT_URL);
  http.addHeader("Content-Type", "application/x-www-form-urlencoded");

  String body = "";
  body += "flow_rate=" + String(flowRate, 2);
  body += "&total_volume=" + String(totalVolume, 2);
  body += "&leak=" + String(leakDetected ? 1 : 0);

  int httpCode = http.POST(body);

  Serial.print("HTTP Response: ");
  Serial.println(httpCode);

  http.end();
}

// ===== URL Encode =====
String urlencode(const String &str) {
  String encoded = "";
  char c;
  for (int i = 0; i < str.length(); i++) {
    c = str.charAt(i);
    if (isalnum(c)) encoded += c;
    else {
      char buf[5];
      sprintf(buf, "%%%02X", c);
      encoded += buf;
    }
  }
  return encoded;
}
/*
  Since Message is READ_WRITE variable, onMessageChange() is
  executed every time a new value is received from IoT Cloud.
*/
// ===== Arduino Cloud Callbacks =====

void onMessageChange() {
  Serial.print("Message updated from dashboard: ");
  Serial.println(message);
}

void onFlowRateChange() {
  Serial.print("Flow rate updated from dashboard: ");
  Serial.println(flow_rate);
}

void onTotalVolumeChange() {
  Serial.print("Total volume updated from dashboard: ");
  Serial.println(total_volume);
}

void onLeakStatusChange() {
  Serial.print("Leak status updated from dashboard: ");
  Serial.println(leak_status ? "LEAK DETECTED" : "NO LEAK");
}

